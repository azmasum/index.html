{
  "version": 2,
  "crons": [
    {
      "path": "/api/cron/daily-deals",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/check-scheduled",
      "schedule": "*/15 * * * *"
    }
  ],
  "routes": [
    { "src": "/api/telegram", "dest": "/api/telegram.js" },
    { "src": "/api/cron/daily-deals", "dest": "/api/cron/daily-deals.js" },
    { "src": "/api/cron/check-scheduled", "dest": "/api/cron/check-scheduled.js" },
    { "src": "/api/post/send", "dest": "/api/post/send.js" },
    { "src": "/api/postback/order", "dest": "/api/postback/order.js" },
    { "src": "/scheduler", "dest": "/scheduler.html" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
