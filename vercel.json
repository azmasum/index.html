{
  "version": 2,
  "crons": [
    {
      "path": "/api/cron/daily-deals",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/check-scheduled",
      "schedule": "*/15 * * * *"
    }
  ],
  "rewrites": [
    { "source": "/api/telegram", "destination": "/api/telegram.js" },
    { "source": "/api/post/send", "destination": "/api/post/send.js" },
    { "source": "/api/postback/order", "destination": "/api/postback/order.js" },
    { "source": "/scheduler", "destination": "/scheduler.html" },
    { "source": "/((?!api|static|.*\\..*).*)", "destination": "/index.html" }
  ]
}
